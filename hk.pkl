amends "package://github.com/jdx/hk/releases/download/v1.45.0/hk@1.45.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.45.0/hk@1.45.0#/Builtins.pkl"

fail_fast = false
env {
  ["HK_MISE"] = "true"
}

local custom_linters = new Mapping<String, Step> {
  ["ansible-lint"] {
    glob =
      List("ansible/**/*.yml", "ansible/**/*.yaml", "ansible/ansible.cfg", "ansible/.ansible-lint")
    check = "cd ansible && ansible-lint"
    fix = "cd ansible && ansible-lint --fix"
  }
}

local builtin_linters = new Mapping<String, Step> {
  ["mise"] = Builtins.mise
  ["pkl"] = Builtins.pkl
  ["pkl-format"] = Builtins.pkl_format
  ["ruff"] = Builtins.ruff
  ["shellcheck"] = Builtins.shellcheck
  ["shfmt"] = Builtins.shfmt
  ["tombi"] = Builtins.tombi
  ["yamlfmt"] = Builtins.yamlfmt
}

local utility_linters = new Mapping<String, Step> {
  ["byte-order-marker"] = Builtins.byte_order_marker
  ["check-added-large-files"] = Builtins.check_added_large_files
  ["check-case-conflict"] = Builtins.check_case_conflict
  ["check-executables-have-shebangs"] = Builtins.check_executables_have_shebangs
  ["check-merge-conflict"] = Builtins.check_merge_conflict
  ["check-symlinks"] = Builtins.check_symlinks
  ["detect-private-key"] = Builtins.detect_private_key
  ["fix-smart-quotes"] = Builtins.fix_smart_quotes
  ["mixed-line-ending"] = Builtins.mixed_line_ending
  ["newlines"] = Builtins.newlines
  ["trailing-whitespace"] = Builtins.trailing_whitespace
}

local all_linters = new Mapping<String, Step> {
  ...custom_linters
  ...builtin_linters
  ...utility_linters
}

hooks {
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps = all_linters
  }
  ["fix"] {
    fix = true
    steps = all_linters
  }
  ["check"] {
    steps = all_linters
  }
}
